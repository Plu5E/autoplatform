# Supabase — kopieer deze waarden uit je Supabase project dashboard
# Settings → API → Project URL en anon/public key
NEXT_PUBLIC_SUPABASE_URL=https://JOUW-PROJECT-ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=JOUW-ANON-KEY

# Supabase service role key (alleen server-side — nooit in NEXT_PUBLIC_)
# Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=JOUW-SERVICE-ROLE-KEY

# Resend API key voor e-mailnotificaties (optioneel voor eerste versie)
# resend.com → API Keys → Create API Key
RESEND_API_KEY=

# Garage standaard e-mail voor notificaties
GARAGE_EMAIL=info@2maal2.be
GARAGE_NAAM=2maal2
